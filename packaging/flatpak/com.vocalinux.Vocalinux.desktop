[Desktop Entry]
Version=1.0
Type=Application
Name=Vocalinux
Comment=Free, offline voice dictation for Linux
GenericName=Voice Typing
Exec=vocalinux
Icon=com.vocalinux.Vocalinux
Terminal=false
