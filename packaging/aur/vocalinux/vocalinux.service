[Unit]
Description=Vocalinux voice dictation daemon
Documentation=https://github.com/jatinkrmalik/vocalinux
PartOf=graphical-session.target
After=graphical-session.target
ConditionEnvironment=WAYLAND_DISPLAY|DISPLAY

[Service]
Type=simple
ExecStart=/usr/bin/vocalinux
Restart=on-failure
RestartSec=3

[Install]
WantedBy=graphical-session.target
